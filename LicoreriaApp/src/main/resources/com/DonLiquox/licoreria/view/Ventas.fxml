<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" prefWidth="700" prefHeight="500" style="-fx-padding: 15; -fx-background-color: #BF95C7;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.VentaController">

    <Label styleClass="titulo" text="Registro de Ventas" />

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="70" prefWidth="70" />
            <ColumnConstraints minWidth="200" prefWidth="200" />
            <ColumnConstraints minWidth="80" prefWidth="80" />
            <ColumnConstraints minWidth="200" prefWidth="200" />
        </columnConstraints>
        <children>
            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Cliente" />
            <ComboBox fx:id="cmbCliente" prefWidth="200" styleClass="input" GridPane.columnIndex="1" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Producto" GridPane.columnIndex="2" />
            <ComboBox fx:id="cmbProducto" prefWidth="200" styleClass="input" GridPane.columnIndex="3" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Cantidad" GridPane.rowIndex="1" />
            <TextField fx:id="txtCantidad" styleClass="input" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Button onAction="#btnAgregar" styleClass="boton" text="Agregar al Carrito" GridPane.columnIndex="3" GridPane.rowIndex="1" />
        </children>
    </GridPane>

    <TableView fx:id="tblCarrito" styleClass="tabla" prefHeight="250" prefWidth="660">
        <columns>
            <TableColumn fx:id="colProd" prefWidth="200" text="Producto" />
            <TableColumn fx:id="colCant" prefWidth="90" text="Cantidad" />
            <TableColumn fx:id="colPrecio" prefWidth="110" text="Precio" />
            <TableColumn fx:id="colSubtotal" prefWidth="110" text="Subtotal" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 5 0 0 0;">
        <Label fx:id="lblTotal" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Total: $0.00" />
        <Button onAction="#btnComprar" styleClass="boton" text="Finalizar Venta" />
    </HBox>

</VBox>

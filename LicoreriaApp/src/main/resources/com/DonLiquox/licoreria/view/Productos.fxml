<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" styleClass="tema-productos" stylesheets="@../../../../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.ProductoController">

    <Label styleClass="titulo" text="Inventario de Productos" />

    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="80.0" />
            <ColumnConstraints minWidth="150.0" />
        </columnConstraints>
        <children>
            <Label style="-fx-text-fill: white;" text="Nombre" />
            <TextField fx:id="txtNombre" styleClass="input" GridPane.columnIndex="1" />

            <Label style="-fx-text-fill: white;" text="Categoría" GridPane.rowIndex="1" />
            <TextField fx:id="txtCategoria" styleClass="input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: white;" text="Precio" GridPane.rowIndex="2" />
            <TextField fx:id="txtPrecio" styleClass="input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label style="-fx-text-fill: white;" text="Stock" GridPane.rowIndex="3" />
            <TextField fx:id="txtStock" styleClass="input" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </children>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#btnGuardar" styleClass="boton" text="Guardar" />
        <Button onAction="#btnActualizar" styleClass="boton" text="Actualizar" />
        <Button onAction="#btnEliminar" styleClass="boton" text="Eliminar" />
        <Button onAction="#btnLimpiar" styleClass="boton" text="Buscar" />
        <TextField fx:id="txtBuscar" promptText="Buscar..." styleClass="input" />
    </HBox>

    <TableView fx:id="tableproductos" prefHeight="200" styleClass="tabla">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="150.0" text="Nombre" />
            <TableColumn fx:id="colCategoria" prefWidth="100.0" text="Categoría" />
            <TableColumn fx:id="colPrecio" prefWidth="75.0" text="Precio" />
            <TableColumn fx:id="colStock" prefWidth="75.0" text="Stock" />
        </columns>
    </TableView>

</VBox>

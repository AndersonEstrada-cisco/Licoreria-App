<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="dashArea" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.DashboardController">

   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="900.0" spacing="15" style="-fx-padding: 10 20; -fx-background-color: #2c3e50;">
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Usuario:">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label fx:id="lblUser" styleClass="lblUser" text="Admin" textFill="WHITE" />
            <Label prefHeight="19.0" prefWidth="115.0" style="-fx-text-fill: white; -fx-font-size: 13px;" text="                       Rol:">
               <font>
                  <Font name="System Bold" size="25.0" />
               </font></Label>
            <Label fx:id="lblRol" styleClass="lblUser" text="Gerente" textFill="WHITE" />
         </children>
      </HBox>
   </top>

   <left>
      <VBox prefWidth="180.0" spacing="5" style="-fx-padding: 10 0;">
         <children>
            <Button fx:id="btnUsuarios" onAction="#btnUsuarios" prefWidth="180" styleClass="btnlateral" text="Usuarios" />
            <Button fx:id="btnClientes" onAction="#btnClientes" prefWidth="180" styleClass="btnlateral" text="Clientes" />
            <Button fx:id="btnVentas" onAction="#btnVentas" prefWidth="180" styleClass="btnlateral" text="Ventas" />
            <Button fx:id="btnProductos" onAction="#btnProductos" prefWidth="180" styleClass="btnlateral" text="Productos" />
            <Button fx:id="btnReportes" onAction="#btnReportes" prefWidth="180" styleClass="btnlateral" text="Reportes" />
            <Button mnemonicParsing="false" onAction="#btnCerrarSesion" prefWidth="180" styleClass="btnlateral" text="Cerrar Sesion" />
         </children>
         <styleClass>
            <String fx:value="lateral" />
            <String fx:value="modulo-base" />
         </styleClass>
      </VBox>
   </left>

</BorderPane>

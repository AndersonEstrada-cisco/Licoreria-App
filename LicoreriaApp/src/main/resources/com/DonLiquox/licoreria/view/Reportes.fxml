<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" prefWidth="700" prefHeight="500" style="-fx-padding: 15; -fx-background-color: #40D69D;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.ReportesController">

    <Label styleClass="titulo" text="Centro de Reportes" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <DatePicker fx:id="fecha" promptText="Seleccione Fecha" styleClass="input" />
        <Button onAction="#generarReporte" styleClass="boton" text="Generar Datos" />
        <Button onAction="#exportarCSV" styleClass="boton" text="Exportar CSV" />
    </HBox>

    <TabPane prefHeight="380" prefWidth="660" tabClosingPolicy="UNAVAILABLE">
        <tabs>
            <Tab text="Estadisticas Visuales">
                <content>
                    <PieChart fx:id="graficoVentas" title="Productos mas vendidos" prefWidth="660" prefHeight="350" />
                </content>
            </Tab>
            <Tab text="Detalle de Ventas">
                <content>
                    <TableView fx:id="tblReporte" styleClass="tabla" prefHeight="350" prefWidth="660">
                        <columns>
                            <TableColumn fx:id="colProducto" prefWidth="250" text="Producto" />
                            <TableColumn fx:id="colCantidad" prefWidth="120" text="Cantidad" />
                            <TableColumn fx:id="colTotal" prefWidth="150" text="Ingreso Total" />
                        </columns>
                    </TableView>
                </content>
            </Tab>
        </tabs>
    </TabPane>

</VBox>

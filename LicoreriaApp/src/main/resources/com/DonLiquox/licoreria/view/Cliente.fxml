<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" styleClass="tema-clientes" stylesheets="@../../../../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.ClienteController">

    <Label styleClass="titulo" text="Gestión de Clientes" />

    <GridPane alignment="CENTER" hgap="15" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="80.0" />
            <ColumnConstraints minWidth="150.0" />
            <ColumnConstraints minWidth="80.0" />
            <ColumnConstraints minWidth="150.0" />
        </columnConstraints>
        <children>
            <Label style="-fx-text-fill: white;" text="Nombre" />
            <TextField fx:id="txtNombre" styleClass="input" GridPane.columnIndex="1" />

            <Label style="-fx-text-fill: white;" text="Cédula" GridPane.rowIndex="1" />
            <TextField fx:id="txtCedula" styleClass="input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: white;" text="Teléfono" GridPane.columnIndex="2" />
            <TextField fx:id="txtTelefono" styleClass="input" GridPane.columnIndex="3" />

            <Label style="-fx-text-fill: white;" text="Email" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="txtEmail" styleClass="input" GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: white;" text="Dirección" GridPane.rowIndex="2" />
            <TextField fx:id="txtDireccion" styleClass="input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label style="-fx-text-fill: white;" text="Edad" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <TextField fx:id="txtEdad" styleClass="input" GridPane.columnIndex="3" GridPane.rowIndex="2" />
        </children>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#btnGuardar" styleClass="boton" text="Guardar" />
        <Button onAction="#btnActualizar" styleClass="boton" text="Actualizar" />
        <Button onAction="#btnEliminar" styleClass="boton" text="Eliminar" />
        <Button onAction="#btnBuscar" styleClass="boton" text="Buscar" />
        <TextField fx:id="txtBuscar" promptText="Buscar..." styleClass="input" />
    </HBox>

    <TableView fx:id="tblClientes" prefHeight="200" styleClass="tabla">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
            <TableColumn fx:id="colCedula" prefWidth="100.0" text="Cédula" />
            <TableColumn fx:id="colEdad" prefWidth="60.0" text="Edad" />
            <TableColumn fx:id="colTelefono" prefWidth="100.0" text="Teléfono" />
            <TableColumn fx:id="colEmail" prefWidth="120.0" text="Email" />
            <TableColumn fx:id="colDireccion" prefWidth="100.0" text="Dirección" />
        </columns>
    </TableView>

</VBox>

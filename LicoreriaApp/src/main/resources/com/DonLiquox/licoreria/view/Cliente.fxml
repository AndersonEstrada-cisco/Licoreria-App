<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" prefWidth="700" prefHeight="500" style="-fx-padding: 15; -fx-background-color: #77dd77;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.ClienteController">

    <Label styleClass="titulo" text="Gestion de Clientes" />

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="70" prefWidth="70" />
            <ColumnConstraints minWidth="160" prefWidth="160" />
            <ColumnConstraints minWidth="70" prefWidth="70" />
            <ColumnConstraints minWidth="160" prefWidth="160" />
        </columnConstraints>
        <children>
            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Nombre" />
            <TextField fx:id="txtNombre" styleClass="input" prefWidth="160" GridPane.columnIndex="1" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Cedula" GridPane.rowIndex="1" />
            <TextField fx:id="txtCedula" styleClass="input" prefWidth="160" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Edad" GridPane.rowIndex="2" />
            <TextField fx:id="txtEdad" styleClass="input" prefWidth="160" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Telefono" GridPane.columnIndex="2" />
            <TextField fx:id="txtTelefono" styleClass="input" prefWidth="160" GridPane.columnIndex="3" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Email" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="txtEmail" styleClass="input" prefWidth="160" GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Direccion" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <TextField fx:id="txtDireccion" styleClass="input" prefWidth="160" GridPane.columnIndex="3" GridPane.rowIndex="2" />
        </children>
    </GridPane>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button onAction="#btnGuardar" styleClass="boton" text="Guardar" />
        <Button onAction="#btnActualizar" styleClass="boton" text="Actualizar" />
        <Button onAction="#btnEliminar" styleClass="boton" text="Eliminar" />
        <Button onAction="#btnLimpiar" styleClass="boton" text="Limpiar" />
        <TextField fx:id="txtBuscar" styleClass="input" promptText="Buscar cliente..." prefWidth="180" />
        <Button onAction="#btnBuscar" styleClass="boton" text="Buscar" />
    </HBox>

    <TableView fx:id="tblClientes" styleClass="tabla" prefHeight="250" prefWidth="660">
        <columns>
            <TableColumn fx:id="colId" prefWidth="40" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="110" text="Nombre" />
            <TableColumn fx:id="colCedula" prefWidth="100" text="Cedula" />
            <TableColumn fx:id="colEdad" prefWidth="50" text="Edad" />
            <TableColumn fx:id="colTelefono" prefWidth="100" text="Telefono" />
            <TableColumn fx:id="colEmail" prefWidth="140" text="Email" />
            <TableColumn fx:id="colDireccion" prefWidth="120" text="Direccion" />
        </columns>
    </TableView>

</VBox>

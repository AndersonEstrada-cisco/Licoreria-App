<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="350.0" styleClass="modulo-base" stylesheets="@../../../../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.DonLiquox.licoreria.controller.LoginController">

   <children>
      <VBox alignment="CENTER" layoutX="75.0" layoutY="50.0" prefWidth="200.0" spacing="15.0" styleClass="modulo-base">
         <children>
            <Label styleClass="titulo" text="DON LIQUOX" />

            <Label  text="Usuario" />
            <TextField fx:id="txtUser" promptText="Ingrese su correo" styleClass="input" />

            <Label  text="Contraseña" />
            <PasswordField fx:id="txtClave" promptText="*******" styleClass="input" />

            <ComboBox fx:id="cmbRol" prefWidth="200.0" />

            <Button mnemonicParsing="false" onAction="#btnIngresar" prefWidth="200.0" styleClass="boton" text="Ingresar" />
         </children>
      </VBox>
   </children>
</AnchorPane>
